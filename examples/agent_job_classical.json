{
  "job_name": "classical_severe_job",
  "dataset_name": "classical_severe_dataset",
  "description": "Starter classical-ML severe weather job with a custom SRH feature contract.",
  "data_source": {
    "kind": "existing_grib_files",
    "samples": [
      {
        "file": "examples/agent_job_sample.grib2",
        "sample_id": "synthetic_severe_0001",
        "messages": []
      }
    ]
  },
  "features": {
    "profiles": [
      "surface_core",
      "severe_diagnostics",
      "tabular_stats"
    ],
    "custom_features": [
      {
        "name": "custom_srh_500m",
        "units": "m2/s2",
        "source": "custom_srh_500m_v1"
      }
    ]
  },
  "labels": [
    {
      "name": "hail_event",
      "source": "report_or_warning"
    }
  ],
  "model": {
    "architecture": "classical_ml",
    "task": "binary_classification",
    "context_steps": 1,
    "notes": [
      "trainer_family=xgboost",
      "row_aggregation=storm_window_stats"
    ]
  },
  "output": {
    "format": "Parquet",
    "shard_count": 2,
    "parallelism": 1,
    "train_fraction": 0.8,
    "validation_fraction": 0.1
  }
}
